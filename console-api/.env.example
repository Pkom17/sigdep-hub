# SIGDEP-3 hub — console-api environment configuration template.
# Copy to .env and fill in the real values for this environment.

# ----------------------------------------------------------------------------
# PostgreSQL (read-mostly access, same database as ingestion-api)
# ----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5436/sigdep
SPRING_DATASOURCE_USERNAME=sigdep
SPRING_DATASOURCE_PASSWORD=sigdep

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
SERVER_PORT=8081

# ----------------------------------------------------------------------------
# Keycloak (used in non-dev profiles)
# ----------------------------------------------------------------------------
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/sigdep

# ----------------------------------------------------------------------------
# Spring profile
# Leave empty in production. Set to 'dev' only for local development.
# ----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=
