# SIGDEP-3 hub — console-api environment configuration template.
# Copy to .env and fill in the real values for this environment.

# ----------------------------------------------------------------------------
# Java runtime (REQUIRED — must be JDK 17 or newer)
# run.sh will use this if set; otherwise on macOS it tries
# /usr/libexec/java_home -v 17 and falls back to whatever 'java' is on PATH.
# Examples:
#   macOS Homebrew  : /opt/homebrew/opt/openjdk@17
#   Ubuntu/Debian   : /usr/lib/jvm/java-17-openjdk-amd64
# ----------------------------------------------------------------------------
JAVA_HOME=

# ----------------------------------------------------------------------------
# PostgreSQL (read-mostly access, same database as ingestion-api)
# ----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5436/sigdep
SPRING_DATASOURCE_USERNAME=sigdep
SPRING_DATASOURCE_PASSWORD=sigdep

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
SERVER_PORT=8081

# ----------------------------------------------------------------------------
# Keycloak — issuer-uri must match the `iss` claim Keycloak puts in JWTs.
# In dev that's whatever KC_HOSTNAME is set to in docker-compose.yml, which
# is the nginx-fronted localhost:9000 origin. Keep these in sync.
# The admin-client URLs below talk to Keycloak directly (no proxy).
# ----------------------------------------------------------------------------
KEYCLOAK_ISSUER_URI=http://localhost:9000/realms/sigdep
KEYCLOAK_SERVER_URL=http://localhost:8180
KEYCLOAK_REALM=sigdep
KEYCLOAK_ADMIN_CLIENT_ID=sigdep-console-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=console-admin-dev-secret-change-me

# ----------------------------------------------------------------------------
# Spring profile
# Leave empty in production. Set to 'dev' only for local development.
# ----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=
