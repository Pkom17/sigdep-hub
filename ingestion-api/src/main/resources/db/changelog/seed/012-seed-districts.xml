<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="012-seed-districts" author="itechciv" failOnError="true">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM core.districts</sqlCheck>
        </preConditions>

        <sql>
            CREATE TEMP TABLE tmp_districts (
                code         VARCHAR(50),
                region_code  VARCHAR(50),
                name         VARCHAR(255),
                source_uuid  CHAR(38)
            ) ON COMMIT DROP;
        </sql>

        <loadData
                file="db/data/districts.csv"
                tableName="tmp_districts"
                relativeToChangelogFile="false"
                separator=","
                quotchar="&quot;"
                encoding="UTF-8">
            <column name="code" type="STRING"/>
            <column name="region_code" type="STRING"/>
            <column name="name" type="STRING"/>
            <column name="source_uuid" type="STRING"/>
        </loadData>

        <sql>
            INSERT INTO core.districts (code, region_id, name, source_uuid)
            SELECT t.code, r.id, t.name, NULLIF(t.source_uuid, '')
            FROM tmp_districts t
            JOIN core.regions r ON r.code = t.region_code;
        </sql>
    </changeSet>

</databaseChangeLog>
