<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="013a-create-stage-sites" author="itechciv" failOnError="true">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM core.sites</sqlCheck>
        </preConditions>
        <sql>
            CREATE TABLE IF NOT EXISTS core.stage_sites (
                code           VARCHAR(50),
                name           VARCHAR(255),
                district_code  VARCHAR(50),
                facility_type  VARCHAR(10),
                source_uuid    CHAR(38)
            );
            TRUNCATE core.stage_sites;
        </sql>
    </changeSet>

    <changeSet id="013b-load-sites" author="itechciv" failOnError="true">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM core.sites</sqlCheck>
        </preConditions>
        <loadData
                file="db/data/sites.csv"
                tableName="stage_sites"
                schemaName="core"
                relativeToChangelogFile="false"
                separator=","
                quotchar="&quot;"
                encoding="UTF-8">
            <column name="code" type="STRING"/>
            <column name="name" type="STRING"/>
            <column name="district_code" type="STRING"/>
            <column name="facility_type" type="STRING"/>
            <column name="source_uuid" type="STRING"/>
        </loadData>
    </changeSet>

    <changeSet id="013c-promote-sites" author="itechciv" failOnError="true">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM core.sites</sqlCheck>
        </preConditions>
        <sql>
            INSERT INTO core.sites (code, name, district_id, facility_type, source_uuid)
            SELECT s.code, s.name, d.id, NULLIF(s.facility_type, ''), NULLIF(s.source_uuid, '')
            FROM core.stage_sites s
            JOIN core.districts d ON d.code = s.district_code;

            DROP TABLE core.stage_sites;
        </sql>
    </changeSet>

</databaseChangeLog>
