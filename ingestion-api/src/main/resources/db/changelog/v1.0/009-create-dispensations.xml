<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="009-create-dispensations" author="itechciv" failOnError="true">
        <createTable tableName="dispensations" schemaName="core">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="patient_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_disp_patient"
                             references="core.patients(id)"/>
            </column>
            <column name="site_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_disp_site"
                             references="core.sites(id)"/>
            </column>
            <column name="source_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="dispensation_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="arv_regimen" type="VARCHAR(100)"/>
            <column name="duration_days" type="INT"/>
            <column name="next_dispensation_date" type="DATE"/>
            <column name="stockout_date" type="DATE"/>
            <column name="extra_data" type="JSONB"/>
            <column name="voided" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="dispensations" schemaName="core"
                             columnNames="site_id, source_uuid"
                             constraintName="uq_disp_site_source"/>

        <createIndex tableName="dispensations" schemaName="core" indexName="idx_disp_patient">
            <column name="patient_id"/>
            <column name="dispensation_date" descending="true"/>
        </createIndex>
        <createIndex tableName="dispensations" schemaName="core" indexName="idx_disp_regimen">
            <column name="arv_regimen"/>
        </createIndex>

        <rollback>
            <dropTable tableName="dispensations" schemaName="core"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
