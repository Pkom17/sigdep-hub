# SIGDEP-3 hub — ingestion-api environment configuration template.
# Copy to .env and fill in the real values for this environment.

# ----------------------------------------------------------------------------
# PostgreSQL (the consolidated database)
# Local dev: 5436 (see infra/docker-compose.yml)
# Staging/prod: real host, real credentials.
# ----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5436/sigdep
SPRING_DATASOURCE_USERNAME=sigdep
SPRING_DATASOURCE_PASSWORD=sigdep

# Liquibase: keep enabled — ingestion-api owns the migrations.
SPRING_LIQUIBASE_ENABLED=true

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
SERVER_PORT=8090

# ----------------------------------------------------------------------------
# Keycloak (used in non-dev profiles)
# ----------------------------------------------------------------------------
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/sigdep

# ----------------------------------------------------------------------------
# Rate limit (per site, requests/minute)
# ----------------------------------------------------------------------------
INGESTION_RATE_LIMIT_PER_SITE=600

# ----------------------------------------------------------------------------
# Spring profile
# Leave empty in production. Set to 'dev' only for local development —
# this disables auth on /api/v1/sync/** (see IngestionSecurityConfig).
# ----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=
