# =============================================================================
# Configuration du hub SIGDEP-3 — copier en .env et compléter.
#
# Toutes ces variables sont lues par docker-compose.prod.yml.
# =============================================================================

# ---- Postgres (base de données principale du hub) -------------------------
POSTGRES_DB=sigdep
POSTGRES_USER=sigdep
POSTGRES_PASSWORD=changeme

# ---- Keycloak (admin master) ---------------------------------------------
# Compte super-admin du serveur Keycloak (différent du SUPER_ADMIN du realm).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# ---- Keycloak (base de données dédiée dans la même instance Postgres) ----
# Si KC_DB_NAME n'existe pas, Keycloak la crée au premier démarrage.
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=changeme

# ---- Keycloak (URL publique) ---------------------------------------------
# Doit correspondre EXACTEMENT à l'URL publique du hub (HTTPS terminé
# par nginx). Toute modification nécessite un restart Keycloak.
KC_HOSTNAME=https://sigdep.example.org
PUBLIC_ORIGIN=https://sigdep.example.org

# ---- Console-api → Keycloak Admin API ------------------------------------
# Secret du client `sigdep-console-admin`. À récupérer dans l'admin
# Keycloak après le premier démarrage (Clients → sigdep-console-admin →
# Credentials → Regenerate), puis remplacer la valeur ci-dessous et
# redémarrer console-api.
KEYCLOAK_ADMIN_CLIENT_SECRET=changeme

# ---- Images Docker publiées sur GHCR --------------------------------------
# Le workflow release.yml du hub publie ces 3 images à chaque tag v*.*.*.
# Épingler la version voulue (recommandé) ou utiliser :latest.
CONSOLE_API_IMAGE=ghcr.io/itech-ci/sigdep-console-api:1.0.3
INGESTION_API_IMAGE=ghcr.io/itech-ci/sigdep-ingestion-api:1.0.3
CONSOLE_WEB_IMAGE=ghcr.io/itech-ci/sigdep-console-web:1.0.3
